{
  "name": "git-sync-tui",
  "type": "module",
  "version": "0.1.10",
  "packageManager": "pnpm@10.32.1",
  "description": "Interactive TUI tool for cross-repo git commit synchronization (cherry-pick --no-commit)",
  "author": "KiWi233333",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KiWi233333/git-sync-tui.git"
  },
  "homepage": "https://github.com/KiWi233333/git-sync-tui#readme",
  "bugs": {
    "url": "https://github.com/KiWi233333/git-sync-tui/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "bin": {
    "git-sync-tui": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "volta": {
    "node": "24.14.0"
  },
  "scripts": {
    "start": "tsx src/cli.tsx",
    "dev": "tsx src/cli.tsx",
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm run release:patch",
    "release:patch": "pnpm version patch && git push --follow-tags",
    "release:minor": "pnpm version minor && git push --follow-tags",
    "release:major": "pnpm version major && git push --follow-tags",
    "release:beta": "pnpm version prerelease --preid=beta && git push --follow-tags",
    "release:retag": "tsx scripts/retag.ts"
  },
  "keywords": [
    "git",
    "sync",
    "cherry-pick",
    "tui",
    "cli",
    "ink",
    "interactive",
    "no-commit"
  ],
  "license": "MIT",
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "ink": "^5.1.0",
    "meow": "^13.0.0",
    "react": "^18.3.1",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
